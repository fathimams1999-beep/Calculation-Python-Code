import numpy as np
import pandas as pd

class DFS_TOPSIS:
    """
    Dodecahedral Fuzzy Set TOPSIS Implementation
    For solar power plant site selection with 12-month seasonal data
    """
    
    def __init__(self, p_norm: float = 2.0):
        self.p = p_norm
        
    def p_norm_normalize(self, vector: np.ndarray) -> np.ndarray:
        """Apply p-norm normalization to satisfy ∑ μ_i^p ≤ 1"""
        norm = np.power(np.sum(np.power(vector, self.p)), 1/self.p)
        if norm == 0:
            return vector
        return vector / norm
    
    def dfs_scalar_multiply(self, d: np.ndarray, weight: float) -> np.ndarray:
        """DFS Scalar Multiplication: w · D"""
        raw = np.power(
            1 - np.power(1 - np.power(d, self.p), weight),
            1/self.p
        )
        return self.p_norm_normalize(raw)
    
    def l_p_distance(self, a: np.ndarray, b: np.ndarray) -> float:
        """Lp distance between two DFS elements"""
        return np.power(np.sum(np.power(np.abs(a - b), self.p)), 1/self.p)


